def main() -> int:
    if not sys.argv[1:]:
        print("mc-sandbox-wrapper: expected Prism to pass the Java command.", file=sys.stderr)
        trace("error: wrapper was called without a Java command")
        return 64

    command = resolve_java_command(sys.argv[1:])
    java_bin = command[0]
    prism_protocol = b""
    if is_prism_bootstrap(command):
        prism_protocol, token, profile_uuid = protect_prism_protocol(sys.stdin.buffer)
    elif looks_like_direct_game(command):
        command, token, profile_uuid = protect_command(command)
    else:
        profile = profile_for(command)
        with tempfile.NamedTemporaryFile("w", prefix="mc-game-sandbox-", suffix=".sb", delete=False) as fh:
            fh.write(profile)
            profile_path = fh.name
        try:
            return subprocess.call(
                ["/usr/bin/sandbox-exec", "-f", profile_path, *command],
                env=sanitized_environment(),
            )
        finally:
            if os.environ.get("MC_SANDBOX_KEEP_PROFILE") != "1":
                Path(profile_path).unlink(missing_ok=True)
    try:
        profile = profile_for(command)
    except SystemExit as exc:
        trace(f"error: {exc}")
        raise
    with tempfile.NamedTemporaryFile("w", prefix="mc-game-sandbox-", suffix=".sb", delete=False) as fh:
        fh.write(profile)
        profile_path = fh.name

    trace(f"launch: java={java_bin} profile={profile_path} argc={len(command)}")
    if os.environ.get("MC_SANDBOX_DEBUG") == "1":
        print(f"mc-sandbox-wrapper: profile at {profile_path}", file=sys.stderr)

    broker = trusted_component(BROKER, "MCGuard broker")
    agent = trusted_component(AGENT, "MCGuard Java agent")
    read_fd, write_fd = os.pipe()
    try:
        os.set_inheritable(read_fd, True)
        os.write(write_fd, token.encode("utf-8", errors="strict"))
    finally:
        os.close(write_fd)

    broker_args = [
        broker,
        "--token-fd", str(read_fd),
        "--profile", profile_path,
        "--agent", agent,
        "--uuid", profile_uuid,
    ]
    protocol_read_fd = -1
    if prism_protocol:
        protocol_read_fd, protocol_write_fd = os.pipe()
        try:
            os.set_inheritable(protocol_read_fd, True)
            written = 0
            while written < len(prism_protocol):
                written += os.write(protocol_write_fd, prism_protocol[written:])
        finally:
            os.close(protocol_write_fd)
        broker_args.extend(["--stdin-fd", str(protocol_read_fd)])
    if os.environ.get("MC_SANDBOX_KEEP_PROFILE") == "1":
        broker_args.append("--keep-profile")
    broker_args.extend(["--", *command])
    clean_env = sanitized_environment()
    trace(f"handoff: token-protection=on broker={broker} profile={profile_path}")
    try:
        os.execve(broker, broker_args, clean_env)
    except OSError:
        os.close(read_fd)
        if protocol_read_fd >= 0:
            os.close(protocol_read_fd)
        Path(profile_path).unlink(missing_ok=True)
        raise


if __name__ == "__main__":
    raise SystemExit(main())
